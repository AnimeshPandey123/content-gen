# Google Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Voice / TTS (Gemini 2.5 Flash TTS)
VOICE_SYNTHESIZER=gemini
TTS_MODEL=gemini-2.5-flash-preview-tts
TTS_VOICE=Kore
TTS_SAMPLE_RATE=24000

# Chatterbox TTS (when VOICE_SYNTHESIZER=chatterbox)
# CHATTERBOX_API_URL=http://127.0.0.1:4123
# CHATTERBOX_VOICE=my-custom-voice
# CHATTERBOX_EXAGGERATION=0.5
# CHATTERBOX_CFG_WEIGHT=0.5
# CHATTERBOX_TEMPERATURE=0.8
# CHATTERBOX_REQUEST_TIMEOUT_SECONDS=120

# Optional safety ceilings (LLM decides section count, scenes, shots, and pacing)
# MAX_SECTIONS=15
# MAX_STORYBOARD_SCENES=20
# MAX_SHOTS_PER_SCENE=8
# MAX_VIDEO_DURATION_SECONDS=120

# Paths
OUTPUT_DIR=output

# PDF extraction
PAGE_IMAGE_DPI=150
SCREENSHOT_PADDING=24.0
SCREENSHOT_EXPAND_FACTOR=3.0
SCREENSHOT_HIGHLIGHT_EXPAND_FACTOR=2.5
SCREENSHOT_FOCUS_MIN_HEIGHT=280.0
SCREENSHOT_HIGHLIGHT_MIN_HEIGHT=200.0
SCREENSHOT_MOBILE_CROP=true

# Video rendering
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
SCREENSHOT_DPI=300
CAMERA_MOTION=static
SCENE_TRANSITION=cut
SCENE_TRANSITION_DURATION=0.5
TTS_FIT_SCENE_DURATION=true
TTS_MAX_TEMPO=1.35
FFMPEG_PATH=ffmpeg
SUBTITLE_FONT_SIZE=72
WORDS_PER_MINUTE=150
NARRATION_SPEED=1.0

# Workflow
MAX_RETRIES=3
RETRY_DELAY_SECONDS=1.0

# Logging
LOG_LEVEL=INFO
LOG_JSON=false
