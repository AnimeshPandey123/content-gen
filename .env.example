# Google Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Section selection
SECTION_SELECTION_LIMIT=5

# Storyboard
STORYBOARD_MAX_SCENES=8

# Paths
OUTPUT_DIR=output

# PDF extraction
PAGE_IMAGE_DPI=150
SCREENSHOT_PADDING=4.0

# Video rendering
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30

# Workflow
MAX_RETRIES=3
RETRY_DELAY_SECONDS=1.0

# Logging
LOG_LEVEL=INFO
LOG_JSON=false
