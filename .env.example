# Google Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Voice / TTS (Gemini 2.5 Flash TTS)
VOICE_SYNTHESIZER=gemini
TTS_MODEL=gemini-2.5-flash-preview-tts
TTS_VOICE=Kore
TTS_SAMPLE_RATE=24000

# Section selection
SECTION_SELECTION_LIMIT=5

# Storyboard
STORYBOARD_MAX_SCENES=8

# Paths
OUTPUT_DIR=output

# PDF extraction
PAGE_IMAGE_DPI=150
SCREENSHOT_PADDING=4.0

# Video rendering
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
SCREENSHOT_DPI=300
CAMERA_MOTION=ken_burns
FFMPEG_PATH=ffmpeg
SUBTITLE_FONT_SIZE=72
WORDS_PER_MINUTE=150
NARRATION_SPEED=1.0

# Workflow
MAX_RETRIES=3
RETRY_DELAY_SECONDS=1.0

# Logging
LOG_LEVEL=INFO
LOG_JSON=false
